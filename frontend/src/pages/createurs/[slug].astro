---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

import { 
  getSiteDataBySlug, 
  getCreatorsForAnnuaire,
  getAssetUrl
} from '../../lib/directus';

// 1. Génération des routes statiques
export async function getStaticPaths() {
  const siteSlug = process.env.SITE_SLUG || 'matikos';
  
  // Ce routage s'applique uniquement à l'annuaire
  if (siteSlug !== 'annuaire-createurs-catholiques') {
    return [];
  }

  const site = await getSiteDataBySlug(siteSlug);
  if (!site) return [];

  const creators = await getCreatorsForAnnuaire();
  
  return creators.map((creator) => ({
    params: { slug: creator.slug },
    props: { creator, site }
  }));
}

const { creator, site } = Astro.props;
const siteSlug = process.env.SITE_SLUG || 'matikos';

const logoUrl = getAssetUrl(creator.logo);
---

<Layout title={`${creator.nom} | Annuaire des Créateurs`} description={creator.specialite} siteSlug={siteSlug}>
  
  <!-- Navbar -->
  <Navbar slot="header" siteNom={site.nom} siteSlug={siteSlug} />

  <!-- En-tête / Hero du Créateur -->
  <div class="bg-gradient-to-br from-amber-600 to-yellow-700 py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="flex flex-col md:flex-row items-center md:items-start space-y-6 md:space-y-0 md:space-x-8 text-center md:text-left">
        <!-- Logo -->
        <div class="h-28 w-28 shrink-0 overflow-hidden rounded-3xl bg-white border-4 border-white shadow-md">
          {logoUrl ? (
            <img src={logoUrl} alt={`Logo de ${creator.nom}`} class="h-full w-full object-cover" />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-amber-100 text-3xl font-bold text-amber-800">
              {creator.nom.substring(0, 2).toUpperCase()}
            </div>
          )}
        </div>

        <div>
          <span class="rounded-full bg-amber-500/30 px-3 py-1 text-xs font-bold uppercase tracking-wider text-amber-100 border border-amber-400/20">
            {creator.specialite}
          </span>
          <h1 class="text-3xl font-extrabold sm:text-4xl md:text-5xl mt-3">{creator.nom}</h1>
          <p class="mt-2 text-amber-100 font-medium">📍 Localisation : {creator.localisation}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Contenu Principal -->
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid gap-12 lg:grid-cols-3">
        
        <!-- Colonne Gauche : Actions et Liens -->
        <div class="lg:col-span-1 space-y-6">
          <div class="rounded-3xl border border-slate-200/60 p-6 bg-slate-50/50">
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-4">Où acheter ?</h3>
            
            <a 
              href={creator.boutique_url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex w-full items-center justify-center rounded-xl bg-amber-600 py-3 text-sm font-semibold text-white shadow-md hover:bg-amber-700 transition-all hover:scale-[1.02] focus:outline-none focus:ring-2 focus:ring-amber-500"
            >
              🛍️ Visiter la boutique en ligne
            </a>

            {creator.instagram_url && (
              <a 
                href={creator.instagram_url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white py-3 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-all mt-4"
              >
                📸 Suivre sur Instagram
              </a>
            )}
          </div>
        </div>

        <!-- Colonne Droite : Description & Galerie de créations -->
        <div class="lg:col-span-2 space-y-12">
          <!-- Description -->
          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Histoire & Savoir-faire</h2>
            <div 
              class="creator-bio-content text-slate-600 leading-relaxed space-y-4"
              set:html={creator.description}
            />
          </div>

          <!-- Galerie de créations (si disponible) -->
          {creator.galerie_creations && creator.galerie_creations.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold text-slate-900 mb-6">Quelques créations</h2>
              <div class="grid gap-6 sm:grid-cols-2">
                {creator.galerie_creations.map((imgUuid) => {
                  const url = getAssetUrl(imgUuid);
                  return url ? (
                    <div class="overflow-hidden rounded-2xl bg-slate-100 aspect-[4/3] border border-slate-100">
                      <img src={url} alt="Création" class="h-full w-full object-cover hover:scale-105 transition-transform duration-500" />
                    </div>
                  ) : null;
                })}
              </div>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer 
    slot="footer" 
    siteNom={site.nom} 
    email="contact@origine.dev"
    siteSlug={siteSlug}
  />

</Layout>

<style is:global>
  .creator-bio-content p {
    @apply mb-4;
  }
  .creator-bio-content strong {
    @apply font-semibold text-slate-900;
  }
</style>
