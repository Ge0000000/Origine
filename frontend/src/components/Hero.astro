---
import { getAssetUrl } from '../lib/directus';

interface Props {
  titre: string;
  description: string;
  imageUuid?: string | null;
  siteSlug: string;
}

const { titre, description, imageUuid, siteSlug } = Astro.props;
const imageUrl = getAssetUrl(imageUuid);

// Thèmes de boutons
const btnThemeMap: Record<string, string> = {
  'matikos': 'bg-emerald-600 hover:bg-emerald-700 focus:ring-emerald-500',
  'le-croisetier': 'bg-blue-600 hover:bg-blue-700 focus:ring-blue-500',
  'annuaire-createurs-catholiques': 'bg-amber-600 hover:bg-amber-700 focus:ring-amber-500',
  'site-c': 'bg-purple-600 hover:bg-purple-700 focus:ring-purple-500'
};

const textThemeMap: Record<string, string> = {
  'matikos': 'text-emerald-200',
  'le-croisetier': 'text-blue-200',
  'annuaire-createurs-catholiques': 'text-amber-200',
  'site-c': 'text-purple-200'
};

const btnTheme = btnThemeMap[siteSlug] || btnThemeMap['matikos'];
const textTheme = textThemeMap[siteSlug] || textThemeMap['matikos'];
---

<section class="relative bg-slate-950 overflow-hidden min-h-[80vh] flex items-center py-24 md:py-32">
  {imageUrl ? (
    <!-- Image de fond si disponible avec effet parallax subtil -->
    <div class="absolute inset-0 opacity-60">
      <img src={imageUrl} alt="Background image" class="h-full w-full object-cover animate-[float_20s_ease-in-out_infinite] scale-105" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-900/80 to-transparent"></div>
    </div>
  ) : (
    <!-- Sinon, dégradé subtil -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-800 opacity-90"></div>
  )}

  <div class="relative mx-auto max-w-7xl px-4 md:px-8 w-full">
    <div class="max-w-3xl backdrop-blur-md bg-slate-900/30 p-6 md:p-12 rounded-3xl border border-white/10 shadow-2xl animate-fade-in-up opacity-0">
      <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl md:text-6xl lg:text-7xl leading-tight drop-shadow-lg">
        {titre}
      </h1>
      <p class={`mt-4 md:mt-6 text-base md:text-xl font-medium leading-relaxed ${textTheme} drop-shadow opacity-0 animate-fade-in-up-delay`}>
        {description}
      </p>
      <div class="mt-10 flex flex-wrap gap-4 opacity-0 animate-fade-in-up-delay-2">
        <a
          href="#contact"
          class={`rounded-full px-8 py-4 text-base font-bold text-white shadow-xl transition-all hover:scale-105 hover:shadow-2xl focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 ${btnTheme}`}
        >
          {siteSlug === 'annuaire-createurs-catholiques' ? 'Découvrir l\'annuaire' : 'Demander un devis gratuit'}
        </a>
        <a
          href={siteSlug === 'annuaire-createurs-catholiques' ? '#createurs' : '#services'}
          class="rounded-full border border-white/20 bg-white/5 px-8 py-4 text-base font-bold text-white backdrop-blur-lg transition-all hover:bg-white/15 hover:border-white/40 hover:scale-105"
        >
          En savoir plus
        </a>
      </div>
    </div>
  </div>
</section>
