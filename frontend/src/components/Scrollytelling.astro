---
// Composant de scrollytelling immersif pour Le Croisetier
// Corrigé : utilise scroll position exacte pour éviter le fond noir, 
// et un calcul précis par étape (pas d'IntersectionObserver qui dérape)
---

<section id="savoir-faire" class="relative">
  <!-- 
    Le conteneur fait 600vh : 100vh de fade-in + 400vh pour 5 étapes + 100vh fade-out.
    La hauteur de sticky est limitée au conteneur grâce à overflow:clip sur le parent.
  -->
  <div id="st-container" class="relative h-[600vh]">

    <!-- Zone sticky : ne dépasse JAMAIS le parent grâce au clip -->
    <div id="st-sticky" class="sticky top-0 h-screen w-full flex flex-col md:flex-row bg-[#090a0f] text-white overflow-hidden">

      <!-- ── VISUEL (gauche) ───────────────────────────────────────── -->
      <div id="st-visual" class="h-[45vh] md:h-full w-full md:w-1/2 relative overflow-hidden bg-black">
        <!-- Overlay dégradé côté droit pour raccorder avec le panneau texte -->
        <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-transparent via-[#090a0f]/20 to-[#090a0f] z-10 pointer-events-none"></div>

        {/* Les 5 images — z-index géré par JS */}
        <div class="st-img absolute inset-0 opacity-0" data-step="0">
          <img src="/images/scrollytelling/etape1.png" alt="Le Ponçage" class="w-full h-full object-cover" loading="eager" />
        </div>
        <div class="st-img absolute inset-0 opacity-0" data-step="1">
          <img src="/images/scrollytelling/etape2.png" alt="La Peinture d'Accroche" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="st-img absolute inset-0 opacity-0" data-step="2">
          <img src="/images/scrollytelling/etape3.png" alt="L'Assemblage" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="st-img absolute inset-0 opacity-0" data-step="3">
          <img src="/images/scrollytelling/etape4.png" alt="La Couleur" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="st-img absolute inset-0 opacity-0" data-step="4">
          <img src="/images/scrollytelling/etape5.png" alt="L'Écrin" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>

      <!-- ── NARRATION (droite) ──────────────────────────────────────── -->
      <div class="h-[55vh] md:h-full w-full md:w-1/2 relative flex items-center justify-center px-6 sm:px-10 md:px-16 lg:px-20 py-10 z-20">

        <!-- Jauge de progression verticale (desktop) -->
        <div class="absolute left-6 lg:left-10 top-1/2 -translate-y-1/2 hidden md:flex flex-col items-center gap-4 z-30">
          <div class="w-px h-40 bg-white/10 relative">
            <div id="st-progress" class="absolute top-0 left-0 w-full bg-blue-500" style="height:0%;transition:height 0.4s ease"></div>
          </div>
          <div class="flex flex-col gap-4">
            {[0,1,2,3,4].map(i => (
              <span class="st-dot text-xs font-bold text-white/30 transition-colors duration-300" data-dot={i}>{String(i+1).padStart(2,'0')}</span>
            ))}
          </div>
        </div>

        <!-- Blocs texte superposés -->
        <div class="relative w-full max-w-md md:pl-6 lg:pl-10">

          {[
            {
              num: '01',
              phase: 'La Préparation',
              titre: 'Le Ponçage du Bois Brut',
              texte: "Tout commence par la réception des pièces en bois brut, livrées en deux parties : le corps de la croix et son socle. Je ponce minutieusement chaque pièce à la main pour lui donner une douceur soyeuse. Les éléments métalliques (le Christ et l'INRI) restent à part pour l'instant."
            },
            {
              num: '02',
              phase: "L'Apprêt",
              titre: "La Peinture d'Accroche",
              texte: "J'applique une sous-couche d'accroche protectrice sur chaque facette de la croix et de sa base en bois, ainsi que sur les éléments métalliques. Cette étape garantit une tenue optimale et durable des finitions colorées."
            },
            {
              num: '03',
              phase: "L'Union",
              titre: "L'Assemblage de la Croix",
              texte: "La sous-couche parfaitement sèche, je fixe solidement la croix sur son socle. Cette union crée la silhouette finale du crucifix, équilibrée et prête à accueillir ses couleurs signatures."
            },
            {
              num: '04',
              phase: "L'Harmonie",
              titre: "Couleur & Montage Final",
              texte: "Deux couches successives de peinture pastel (Rose poudré, Vert sauge ou Bleu céleste) recouvrent le bois. Le Christ et l'INRI reçoivent une couche blanche épurée. Je cloue ensuite le Christ et colle l'INRI avec précision."
            },
            {
              num: '05',
              phase: "L'Écrin",
              titre: "La Signature et l'Envoi",
              texte: "L'autocollant signature est collé sur la boîte à plat avant le pliage. J'installe un lit de papier de soie, j'y dépose délicatement le crucifix et j'ajoute une carte de remerciement personnelle avant de refermer l'écrin."
            }
          ].map((step, i) => (
            <div class="st-text absolute inset-0 flex flex-col justify-center opacity-0" data-step={i} style="transition: opacity 0.6s ease, transform 0.6s ease; transform: translateY(20px);">
              <span class="text-blue-400 font-bold uppercase tracking-widest text-xs mb-1 font-inter">Étape {step.num} — {step.phase}</span>
              <h3 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white tracking-tight leading-tight mb-4">{step.titre}</h3>
              <p class="text-slate-300 text-sm sm:text-base lg:text-lg leading-relaxed">{step.texte}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (() => {
    const STEPS = 5;
    const FADE_VH = 0.8; // 80% d'un vh pour le fade-in/out global

    const init = () => {
      const container  = document.getElementById('st-container');
      const sticky     = document.getElementById('st-sticky');
      const imgs       = Array.from(document.querySelectorAll<HTMLElement>('.st-img'));
      const texts      = Array.from(document.querySelectorAll<HTMLElement>('.st-text'));
      const dots       = Array.from(document.querySelectorAll<HTMLElement>('.st-dot'));
      const progress   = document.getElementById('st-progress');

      if (!container || !sticky) return;

      let rafId: number | null = null;
      let lastStep = -1;

      const setStep = (step: number, globalOpacity: number) => {
        // Opacité globale de la section (fondu entrée/sortie)
        sticky.style.opacity = String(globalOpacity);

        if (step === lastStep) return;
        lastStep = step;

        // Images
        imgs.forEach(el => {
          const s = Number(el.dataset.step);
          el.style.opacity   = s === step ? '1' : '0';
          el.style.transform = s === step ? 'scale(1)' : 'scale(1.05)';
          el.style.transition = 'opacity 0.9s ease, transform 1.2s ease';
        });

        // Textes
        texts.forEach(el => {
          const s = Number(el.dataset.step);
          el.style.opacity   = s === step ? '1' : '0';
          el.style.transform = s === step ? 'translateY(0)' : 'translateY(20px)';
          (el as HTMLElement).style.pointerEvents = s === step ? 'auto' : 'none';
        });

        // Dots
        dots.forEach(el => {
          const active = Number(el.dataset.dot) === step;
          el.style.color = active ? '#3b82f6' : 'rgba(255,255,255,0.3)';
        });

        // Barre de progression
        if (progress) {
          progress.style.height = `${(step / (STEPS - 1)) * 100}%`;
        }
      };

      const onScroll = () => {
        if (rafId !== null) return;
        rafId = requestAnimationFrame(() => {
          rafId = null;
          const rect = container.getBoundingClientRect();
          const vh   = window.innerHeight;

          // rect.top : distance entre le haut du container et le haut du viewport
          // Quand rect.top < 0, on est dans la section
          // rect.bottom : quand rect.bottom <= vh, on est sorti par le bas

          const scrolled = -rect.top; // pixels scrollés dans la section

          if (scrolled < 0) {
            // Avant la section — fade-in
            const t = Math.max(0, 1 + scrolled / (vh * FADE_VH));
            setStep(0, t);
            return;
          }

          const totalScroll = rect.height - vh; // hauteur scrollable totale
          if (scrolled >= totalScroll) {
            // Après la section — fade-out
            const over = scrolled - totalScroll;
            const t = Math.max(0, 1 - over / (vh * FADE_VH));
            setStep(STEPS - 1, t);
            return;
          }

          // Dans la section : répartir les 5 étapes sur 400vh (=totalScroll - 200vh de fade)
          // On déduit 1 vh de fade-in et 1 vh de fade-out des extremités
          const innerStart  = vh * FADE_VH * 0.5;
          const innerEnd    = totalScroll - vh * FADE_VH * 0.5;
          const innerScroll = Math.max(0, Math.min(scrolled - innerStart, innerEnd - innerStart));
          const innerRange  = innerEnd - innerStart;

          const step = Math.min(STEPS - 1, Math.floor((innerScroll / innerRange) * STEPS));
          setStep(step, 1);
        });
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll(); // init immédiate
    };

    // Lancer au chargement et après les ViewTransitions Astro
    document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('astro:after-swap', init);
    if (document.readyState !== 'loading') init();
  })();
</script>

<style>
  /* Le conteneur parent coupe le sticky grâce à overflow:clip
     On ne peut PAS mettre overflow:hidden (ça casserait position:sticky),
     on cible uniquement l'axe X pour la sécurité */
  #st-container {
    overflow-x: clip;
  }
  #st-sticky {
    will-change: opacity;
  }
  .st-img {
    will-change: opacity, transform;
  }
  .st-text {
    will-change: opacity, transform;
  }
</style>
