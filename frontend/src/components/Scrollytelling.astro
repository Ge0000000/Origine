---
// Composant de scrollytelling immersif pour Le Croisetier
// Décrit le processus de fabrication artisanale d'un crucifix
---

<section id="savoir-faire" class="relative bg-slate-950">
  <!-- Conteneur global de défilement (5 étapes = 500vh) -->
  <div class="relative h-[500vh]">
    
    <!-- Écran fixe (Sticky) pendant la traversée -->
    <div class="sticky top-0 h-screen w-full flex flex-col md:flex-row overflow-hidden bg-[#090a0f] text-white">
      
      <!-- Partie Visuelle (Gauche sur Desktop, Haut sur Mobile) -->
      <div class="h-[40vh] md:h-full w-full md:w-1/2 relative overflow-hidden bg-slate-900 border-b md:border-b-0 md:border-r border-white/5">
        <!-- Overlay dégradé pour intégrer l'image au design sombre -->
        <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-transparent via-[#090a0f]/30 to-[#090a0f] z-10 pointer-events-none"></div>
        
        <!-- Étape 1 : Le Ponçage -->
        <div class="absolute inset-0 w-full h-full opacity-100 transition-all duration-1000 ease-in-out scale-100 z-0 step-img" data-step="0">
          <img src="/images/scrollytelling/etape1.png" alt="Le Ponçage des pièces en bois" class="w-full h-full object-cover" />
        </div>
        
        <!-- Étape 2 : L'Apprêt -->
        <div class="absolute inset-0 w-full h-full opacity-0 transition-all duration-1000 ease-in-out scale-105 z-0 step-img" data-step="1">
          <img src="/images/scrollytelling/etape2.png" alt="Application de la peinture d'accroche" class="w-full h-full object-cover" />
        </div>
        
        <!-- Étape 3 : L'Union -->
        <div class="absolute inset-0 w-full h-full opacity-0 transition-all duration-1000 ease-in-out scale-105 z-0 step-img" data-step="2">
          <img src="/images/scrollytelling/etape3.png" alt="Assemblage de la croix et du socle" class="w-full h-full object-cover" />
        </div>
        
        <!-- Étape 4 : L'Harmonie -->
        <div class="absolute inset-0 w-full h-full opacity-0 transition-all duration-1000 ease-in-out scale-105 z-0 step-img" data-step="3">
          <img src="/images/scrollytelling/etape4.png" alt="Mise en couleur pastel et pose du Christ" class="w-full h-full object-cover" />
        </div>
        
        <!-- Étape 5 : L'Écrin -->
        <div class="absolute inset-0 w-full h-full opacity-0 transition-all duration-1000 ease-in-out scale-105 z-0 step-img" data-step="4">
          <img src="/images/scrollytelling/etape5.png" alt="Mise en boîte cadeau finale" class="w-full h-full object-cover" />
        </div>
      </div>
      
      <!-- Partie Narrative (Droite sur Desktop, Bas sur Mobile) -->
      <div class="h-[60vh] md:h-full w-full md:w-1/2 relative flex items-center justify-center p-6 sm:p-12 md:p-20 z-20">
        
        <!-- Indicateur de progression vertical (Desktop uniquement) -->
        <div class="absolute left-8 lg:left-12 top-1/2 -translate-y-1/2 hidden md:flex flex-col items-center gap-6 z-30">
          <div class="w-0.5 h-48 bg-white/10 relative">
            <div id="progress-bar" class="absolute top-0 left-0 w-full h-0 bg-blue-500 transition-all duration-500"></div>
          </div>
          <div class="flex flex-col gap-6 text-xs font-bold text-white/40 font-inter">
            <span class="step-dot transition-colors duration-500 text-blue-500" data-dot="0">01</span>
            <span class="step-dot transition-colors duration-500" data-dot="1">02</span>
            <span class="step-dot transition-colors duration-500" data-dot="2">03</span>
            <span class="step-dot transition-colors duration-500" data-dot="3">04</span>
            <span class="step-dot transition-colors duration-500" data-dot="4">05</span>
          </div>
        </div>

        <!-- Textes des étapes -->
        <div class="relative w-full max-w-lg md:pl-8 lg:pl-12">
          
          <!-- Étape 1 : Le Ponçage -->
          <div class="absolute inset-0 flex flex-col justify-center transition-all duration-700 opacity-100 translate-y-0 pointer-events-auto step-text" data-step="0">
            <span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 font-inter">Étape 01 — La Préparation</span>
            <h3 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-tight mb-4 animate-fade-in">
              Le Ponçage du Bois Brut
            </h3>
            <p class="text-slate-300 text-base sm:text-lg leading-relaxed">
              Tout commence par la réception des pièces en bois brut, livrées en deux parties distinctes : le corps de la croix et son socle. Je ponce minutieusement chaque pièce à la hand pour éliminer les aspérités et lui donner une douceur soyeuse. Les éléments en métal (le Christ et l'INRI) restent à part pour l'instant.
            </p>
          </div>
          
          <!-- Étape 2 : L'Apprêt -->
          <div class="absolute inset-0 flex flex-col justify-center transition-all duration-700 opacity-0 translate-y-8 pointer-events-none step-text" data-step="1">
            <span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 font-inter">Étape 02 — L'Apprêt</span>
            <h3 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-tight mb-4">
              La Peinture d'Accroche
            </h3>
            <p class="text-slate-300 text-base sm:text-lg leading-relaxed">
              Pour assurer une tenue optimale et durable des finitions, j'applique avec soin une sous-couche d'accroche protectrice. Cette peinture d'accroche recouvre chaque facette de la croix et de sa base en bois, ainsi que les éléments métalliques du Christ et du panneau INRI.
            </p>
          </div>
          
          <!-- Étape 3 : L'Union -->
          <div class="absolute inset-0 flex flex-col justify-center transition-all duration-700 opacity-0 translate-y-8 pointer-events-none step-text" data-step="2">
            <span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 font-inter">Étape 03 — L'Union</span>
            <h3 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-tight mb-4">
              L'Assemblage de la Croix
            </h3>
            <p class="text-slate-300 text-base sm:text-lg leading-relaxed">
              Une fois la sous-couche parfaitement sèche, vient le moment de l'assemblage physique. J'emboîte et je fixe solidement la croix sur son socle. Cette union crée la silhouette finale du crucifix, équilibrée et prête à accueillir ses couleurs.
            </p>
          </div>
          
          <!-- Étape 4 : L'Harmonie -->
          <div class="absolute inset-0 flex flex-col justify-center transition-all duration-700 opacity-0 translate-y-8 pointer-events-none step-text" data-step="3">
            <span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 font-inter">Étape 04 — L'Harmonie</span>
            <h3 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-tight mb-4">
              Couleur & Montage Final
            </h3>
            <p class="text-slate-300 text-base sm:text-lg leading-relaxed">
              J'applique deux couches successives de peinture pastel (soit Rose poudré, Vert sauge, ou Bleu céleste) sur la structure en bois. Les éléments métalliques reçoivent une couche de blanc pur. Enfin, je cloue avec soin le Christ au centre de la croix et je colle l'INRI juste au-dessus.
            </p>
          </div>
          
          <!-- Étape 5 : L'Écrin -->
          <div class="absolute inset-0 flex flex-col justify-center transition-all duration-700 opacity-0 translate-y-8 pointer-events-none step-text" data-step="4">
            <span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 font-inter">Étape 05 — L'Écrin</span>
            <h3 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-tight mb-4">
              La Signature et l'Envoi
            </h3>
            <p class="text-slate-300 text-base sm:text-lg leading-relaxed">
              L'expérience continue dans les détails de l'emballage. Je colle d'abord notre autocollant signature sur la boîte en carton encore à plat, puis je procède aux pliages. J'y dispose un papier de soie protecteur, j'y dépose le crucifix et j'ajoute une carte de remerciement personnelle avant de refermer délicatement l'écrin.
            </p>
          </div>
          
        </div>
      </div>
      
    </div>
    
    <!-- Déclencheurs de Scroll Invisibles (Absolute) répartis dans les 500vh -->
    <div class="absolute inset-0 flex flex-col pointer-events-none z-0">
      <div class="h-screen scroll-trigger" data-step="0"></div>
      <div class="h-screen scroll-trigger" data-step="1"></div>
      <div class="h-screen scroll-trigger" data-step="2"></div>
      <div class="h-screen scroll-trigger" data-step="3"></div>
      <div class="h-screen scroll-trigger" data-step="4"></div>
    </div>
    
  </div>
</section>

<script>
  // Script client pour gérer le scrollytelling
  const initScrollytelling = () => {
    const triggers = document.querySelectorAll('.scroll-trigger');
    const images = document.querySelectorAll('.step-img');
    const texts = document.querySelectorAll('.step-text');
    const dots = document.querySelectorAll('.step-dot');
    const progressBar = document.getElementById('progress-bar');
    
    if (triggers.length === 0) return;

    let activeStep = 0;

    const updateUI = (step: number) => {
      if (step === activeStep) return;
      activeStep = step;

      // Mettre à jour la barre de progression (ex: 0 -> 0%, 4 -> 100%)
      if (progressBar) {
        const percentage = (step / (triggers.length - 1)) * 100;
        progressBar.style.height = `${percentage}%`;
      }

      // Mettre à jour les images
      images.forEach((img) => {
        const s = parseInt(img.getAttribute('data-step') || '0', 10);
        if (s === step) {
          img.classList.remove('opacity-0');
          img.classList.add('opacity-100');
          img.classList.remove('scale-105');
          img.classList.add('scale-100');
        } else {
          img.classList.remove('opacity-100');
          img.classList.add('opacity-0');
          img.classList.remove('scale-100');
          img.classList.add('scale-105');
        }
      });

      // Mettre à jour les textes
      texts.forEach((txt) => {
        const s = parseInt(txt.getAttribute('data-step') || '0', 10);
        const element = txt as HTMLElement;
        if (s === step) {
          element.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
          element.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        } else {
          element.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
          element.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
        }
      });

      // Mettre à jour les numéros de la barre de progression
      dots.forEach((dot) => {
        const s = parseInt(dot.getAttribute('data-dot') || '0', 10);
        if (s === step) {
          dot.classList.add('text-blue-500');
          dot.classList.remove('text-white/40');
        } else {
          dot.classList.remove('text-blue-500');
          dot.classList.add('text-white/40');
        }
      });
    };

    // Utilisation d'un IntersectionObserver pour détecter l'entrée des triggers
    const observerOptions = {
      root: null, // Viewport
      rootMargin: '-30% 0px -30% 0px', // Seuil au milieu de l'écran
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const step = parseInt(entry.target.getAttribute('data-step') || '0', 10);
          updateUI(step);
        }
      });
    }, observerOptions);

    triggers.forEach((trigger) => observer.observe(trigger));
  };

  // Lancer au chargement de la page et après navigation Astro (ViewTransitions)
  document.addEventListener('DOMContentLoaded', initScrollytelling);
  document.addEventListener('astro:after-swap', initScrollytelling);
  
  // Exécuter également immédiatement si le script est injecté de façon dynamique
  initScrollytelling();
</script>

<style>
  /* Transition spécifique pour le fondu des images */
  .step-img {
    transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1), transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
</style>
