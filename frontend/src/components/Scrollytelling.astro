---
// Composant de scrollytelling immersif pour Le Croisetier
// Corrigé : utilise scroll position exacte pour éviter le fond noir, 
// et un calcul précis par étape (pas d'IntersectionObserver qui dérape)
---

<section id="savoir-faire" class="relative">
  <!-- 
    Le conteneur fait 500vh : 5 étapes de 100vh chacune de scroll.
    La hauteur de sticky est limitée au conteneur grâce à overflow:clip sur le parent.
  -->
  <div id="st-container" class="relative h-[500vh]">

    <!-- Zone sticky : prend 100% du viewport en plein écran -->
    <div id="st-sticky" class="sticky top-0 h-screen w-full bg-[#050608] text-white overflow-hidden flex items-center justify-center">

      <!-- ── VISUEL EN ARRIÈRE-PLAN PLEIN ÉCRAN ─────────────────────── -->
      <div id="st-background" class="absolute inset-0 w-full h-full bg-black z-0 overflow-hidden">
        <!-- Overlay sombre dégradé pour garantir le contraste et la lisibilité du texte -->
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/65 to-slate-950/40 z-10 pointer-events-none"></div>

        {/* Les 5 images cinématiques */}
        <div class="st-img absolute inset-0 opacity-0 scale-105" data-step="0">
          <img src="/images/scrollytelling/etape1.png" alt="Le Ponçage du Bois Brut" class="w-full h-full object-cover" loading="eager" />
        </div>
        <div class="st-img absolute inset-0 opacity-0 scale-105" data-step="1">
          <img src="/images/scrollytelling/etape2.png" alt="La Peinture d'Accroche" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="st-img absolute inset-0 opacity-0 scale-105" data-step="2">
          <img src="/images/scrollytelling/etape3.png" alt="L'Assemblage de la Croix" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="st-img absolute inset-0 opacity-0 scale-105" data-step="3">
          <img src="/images/scrollytelling/etape4.png" alt="La Couleur Pastel et Montage" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="st-img absolute inset-0 opacity-0 scale-105" data-step="4">
          <img src="/images/scrollytelling/etape5.png" alt="La Signature et l'Envoi" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>

      <!-- ── NARRATION CENTRÉE (z-20 par-dessus le fond) ───────────── -->
      <div class="relative z-20 w-full max-w-3xl px-6 sm:px-10 py-12 flex items-center justify-center min-h-[60vh]">
        <!-- Blocs texte superposés -->
        <div class="relative w-full text-center flex items-center justify-center">

          {[
            {
              num: '01',
              phase: 'La Préparation',
              titre: 'Le Ponçage du Bois Brut',
              texte: "Tout commence par la réception des pièces en bois brut, livrées en deux parties : le corps de la croix et son socle. Je ponce minutieusement chaque pièce à la main pour lui donner une douceur soyeuse. Les éléments métalliques (le Christ et l'INRI) restent à part pour l'instant."
            },
            {
              num: '02',
              phase: "L'Apprêt",
              titre: "La Peinture d'Accroche",
              texte: "J'applique une sous-couche d'accroche protectrice sur chaque facette de la croix et de sa base en bois, ainsi que sur les éléments métalliques. Cette étape garantit une tenue optimale et durable des finitions colorées."
            },
            {
              num: '03',
              phase: "L'Union",
              titre: "L'Assemblage de la Croix",
              texte: "La sous-couche parfaitement sèche, je fixe solidement la croix sur son socle. Cette union crée la silhouette finale du crucifix, équilibrée et prête à accueillir ses couleurs signatures."
            },
            {
              num: '04',
              phase: "L'Harmonie",
              titre: "Couleur & Montage Final",
              texte: "Deux couches successives de peinture pastel (Rose poudré, Vert sauge ou Bleu céleste) recouvrent le bois. Le Christ et l'INRI reçoivent une couche blanche épurée. Je cloue ensuite le Christ et colle l'INRI avec précision."
            },
            {
              num: '05',
              phase: "L'Écrin",
              titre: "La Signature et l'Envoi",
              texte: "L'autocollant signature est collé sur la boîte à plat avant le pliage. J'installe un lit de papier de soie, j'y dépose délicatement le crucifix et j'ajoute une carte de remerciement personnelle avant de refermer l'écrin."
            }
          ].map((step, i) => (
            <div 
              class="st-text absolute inset-0 flex flex-col items-center justify-center opacity-0 pointer-events-none select-none max-w-xl mx-auto" 
              data-step={i} 
              style="transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1); transform: translateY(30px);"
            >
              <span class="text-blue-400 font-bold uppercase tracking-widest text-xs sm:text-sm mb-3 font-inter">Étape {step.num} — {step.phase}</span>
              <h3 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight mb-6 font-inter">{step.titre}</h3>
              <p class="text-slate-200 text-sm sm:text-base lg:text-lg leading-relaxed font-light">{step.texte}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Barre de progression horizontale discrète en bas de l'écran -->
      <div class="absolute bottom-0 left-0 w-full h-1 bg-white/10 z-30">
        <div id="st-progress" class="h-full bg-blue-500 transition-all duration-300 ease-out" style="width: 0%;"></div>
      </div>

      <!-- Barre de navigation verticale interactive sur le côté droit -->
      <div id="st-nav" class="absolute right-4 sm:right-8 top-1/2 -translate-y-1/2 flex flex-col gap-6 z-40 select-none">
        {[
          { label: 'Ponçage', num: '01' },
          { label: 'Apprêt', num: '02' },
          { label: 'Assemblage', num: '03' },
          { label: 'Couleur', num: '04' },
          { label: 'Écrin', num: '05' }
        ].map((item, i) => (
          <button
            class="st-nav-btn group relative flex items-center justify-end w-6 h-6 focus:outline-none cursor-pointer"
            data-target-step={i}
            aria-label={`Aller à l'étape ${item.num} - ${item.label}`}
          >
            <!-- Libellé de l'étape au hover (desktop uniquement) -->
            <span class="absolute right-8 top-1/2 -translate-y-1/2 px-3 py-1.5 bg-slate-950/95 text-white text-xs font-semibold rounded-lg border border-slate-800 pointer-events-none opacity-0 translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 whitespace-nowrap hidden md:block shadow-md">
              {item.num}. {item.label}
            </span>
            <!-- Petit rond indicateur cliquable -->
            <span class="st-nav-dot w-3 h-3 rounded-full border border-white/30 bg-white/10 hover:border-white/60 transition-all duration-300 group-hover:scale-125"></span>
          </button>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  (() => {
    const STEPS = 5;

    const init = () => {
      const container = document.getElementById('st-container');
      const sticky    = document.getElementById('st-sticky');
      const imgs      = Array.from(document.querySelectorAll<HTMLElement>('.st-img'));
      const texts     = Array.from(document.querySelectorAll<HTMLElement>('.st-text'));
      const navBtns   = Array.from(document.querySelectorAll<HTMLElement>('.st-nav-btn'));
      const progress  = document.getElementById('st-progress');

      if (!container || !sticky) return;

      let rafId: number | null = null;
      let lastStep = -1;

      const setStep = (step: number) => {
        if (step === lastStep) return;
        lastStep = step;

        // Images - Crossfade cinématique et zoom avant délicat
        imgs.forEach(el => {
          const s = Number(el.dataset.step);
          const active = s === step;
          el.style.opacity = active ? '1' : '0';
          el.style.transform = active ? 'scale(1)' : 'scale(1.05)';
          el.style.transition = 'opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1.5s cubic-bezier(0.16, 1, 0.3, 1)';
          el.style.zIndex = active ? '5' : '1';
        });

        // Textes - Révélation et glissement vertical (slide up)
        texts.forEach(el => {
          const s = Number(el.dataset.step);
          const active = s === step;
          el.style.opacity = active ? '1' : '0';
          
          if (active) {
            el.style.transform = 'translateY(0)';
            el.style.pointerEvents = 'auto';
          } else if (s < step) {
            el.style.transform = 'translateY(-40px)';
            el.style.pointerEvents = 'none';
          } else {
            el.style.transform = 'translateY(40px)';
            el.style.pointerEvents = 'none';
          }
          el.style.transition = 'opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1)';
        });

        // Ronds indicateurs latéraux
        navBtns.forEach(btn => {
          const s = Number(btn.dataset.targetStep);
          const dot = btn.querySelector('.st-nav-dot') as HTMLElement;
          if (dot) {
            if (s === step) {
              dot.style.backgroundColor = '#3b82f6';
              dot.style.borderColor = '#60a5fa';
              dot.style.boxShadow = '0 0 10px #3b82f6, inset 0 0 4px #fff';
              dot.style.transform = 'scale(1.25)';
            } else {
              dot.style.backgroundColor = 'rgba(255,255,255,0.1)';
              dot.style.borderColor = 'rgba(255,255,255,0.3)';
              dot.style.boxShadow = 'none';
              dot.style.transform = 'scale(1)';
            }
          }
        });

        // Barre de progression
        if (progress) {
          progress.style.width = `${(step / (STEPS - 1)) * 100}%`;
        }
      };

      const onScroll = () => {
        if (rafId !== null) return;
        rafId = requestAnimationFrame(() => {
          rafId = null;
          const rect = container.getBoundingClientRect();
          const vh   = window.innerHeight;

          const scrolled = -rect.top; // pixels scrollés dans la section
          const totalScroll = rect.height - vh; // hauteur scrollable totale

          if (scrolled < 0) {
            setStep(0);
            return;
          }

          if (scrolled >= totalScroll) {
            setStep(STEPS - 1);
            return;
          }

          // Dans la section : découpage proportionnel des 5 étapes
          const progressPercent = Math.max(0, Math.min(scrolled / totalScroll, 1));
          const step = Math.min(STEPS - 1, Math.floor(progressPercent * STEPS));
          setStep(step);
        });
      };

      // Clic de navigation pour sauter à une étape
      navBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const targetStep = Number(btn.dataset.targetStep);
          const rect = container.getBoundingClientRect();
          const vh = window.innerHeight;
          const totalScroll = rect.height - vh;
          
          // Calculer la position absolue actuelle du conteneur dans la page
          const containerAbsoluteTop = window.scrollY + rect.top;
          const targetScroll = containerAbsoluteTop + (targetStep / (STEPS - 1)) * totalScroll;
          
          window.scrollTo({
            top: targetScroll,
            behavior: 'smooth'
          });
        });
      });

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll(); // init immédiate
    };

    // Lancer au chargement et après les swaps Astro
    document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('astro:after-swap', init);
    if (document.readyState !== 'loading') init();
  })();
</script>

<style>
  #st-container {
    overflow-x: clip;
  }
  .st-img {
    will-change: opacity, transform;
  }
  .st-text {
    will-change: opacity, transform;
  }
</style>
