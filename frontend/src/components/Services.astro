---
interface Props {
  services: string[];
  siteSlug: string;
}

const { services, siteSlug } = Astro.props;

// Icônes de démo pour chaque type de service
const getIcon = (service: string) => {
  const s = service.toLowerCase();
  if (s.includes('menuiserie') || s.includes('bois')) {
    return '🔨';
  }
  if (s.includes('plâtre') || s.includes('peinture')) {
    return '🎨';
  }
  if (s.includes('isolation') || s.includes('cloisons')) {
    return '🏠';
  }
  if (s.includes('rénovation') || s.includes('finitions')) {
    return '✨';
  }
  return '🛠️';
};

// Styles de thème
const themeColors: Record<string, { bg: string; border: string; text: string }> = {
  'matikos': {
    bg: 'bg-emerald-50/50',
    border: 'border-emerald-100 hover:border-emerald-200',
    text: 'text-emerald-700'
  },
  'le-croisetier': {
    bg: 'bg-blue-50/50',
    border: 'border-blue-100 hover:border-blue-200',
    text: 'text-blue-700'
  },
  'annuaire-createurs-catholiques': {
    bg: 'bg-amber-50/50',
    border: 'border-amber-100 hover:border-amber-200',
    text: 'text-amber-700'
  },
  'site-c': {
    bg: 'bg-purple-50/50',
    border: 'border-purple-100 hover:border-purple-200',
    text: 'text-purple-700'
  }
};

const theme = themeColors[siteSlug] || themeColors['matikos'];
---

<section id="services" class="py-24 bg-slate-50 relative overflow-hidden">
  <!-- Élément décoratif en fond -->
  <div class={`absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 rounded-full blur-3xl opacity-20 ${theme.bg}`}></div>
  
  <div class="relative mx-auto max-w-7xl px-4 md:px-8">
    <div class="text-center max-w-3xl mx-auto mb-20 reveal-on-scroll">
      <h2 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl mb-6">Nos Services & Expertises</h2>
      <p class="text-lg md:text-xl text-slate-600 leading-relaxed">
        Découvrez l'étendue de nos compétences et notre engagement pour des travaux de qualité supérieure, durables et soignés.
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service, index) => (
        <div class={`group relative p-8 rounded-3xl bg-white shadow-sm hover:shadow-2xl transition-all duration-500 ease-in-out hover:-translate-y-2 border border-slate-100 ${theme.border} reveal-on-scroll`} style={`transition-delay: ${index * 100}ms;`}>
          <!-- Cercle décoratif de la carte -->
          <div class={`absolute -top-4 -right-4 w-24 h-24 rounded-full opacity-0 group-hover:opacity-10 transition-opacity duration-500 ${theme.bg}`}></div>
          
          <div class={`relative inline-flex h-16 w-16 items-center justify-center rounded-2xl text-3xl mb-8 shadow-inner transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 ${theme.bg}`}>
            {getIcon(service)}
          </div>
          <h3 class="relative text-2xl font-bold text-slate-900 mb-4 group-hover:text-slate-800">{service}</h3>
          <p class="relative text-base text-slate-500 leading-relaxed group-hover:text-slate-600 transition-colors">
            Prestation sur-mesure réalisée dans les règles de l'art par un artisan qualifié avec un suivi minutieux de votre chantier.
          </p>
          
          <div class="mt-8 flex items-center">
             <span class={`text-sm font-semibold flex items-center gap-2 ${theme.text} opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300`}>
                En savoir plus <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
             </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
