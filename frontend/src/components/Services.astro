---
interface Props {
  services: string[];
  siteSlug: string;
}

const { services, siteSlug } = Astro.props;

// Icônes de démo pour chaque type de service
const getIcon = (service: string) => {
  const s = service.toLowerCase();
  if (s.includes('menuiserie') || s.includes('bois')) {
    return '🔨';
  }
  if (s.includes('plâtre') || s.includes('peinture')) {
    return '🎨';
  }
  if (s.includes('isolation') || s.includes('cloisons')) {
    return '🏠';
  }
  if (s.includes('rénovation') || s.includes('finitions')) {
    return '✨';
  }
  return '🛠️';
};

// Styles de thème
const themeColors: Record<string, { bg: string; border: string; text: string }> = {
  'matikos': {
    bg: 'bg-emerald-50/50',
    border: 'border-emerald-100 hover:border-emerald-200',
    text: 'text-emerald-700'
  },
  'le-croisetier': {
    bg: 'bg-blue-50/50',
    border: 'border-blue-100 hover:border-blue-200',
    text: 'text-blue-700'
  },
  'annuaire-createurs-catholiques': {
    bg: 'bg-amber-50/50',
    border: 'border-amber-100 hover:border-amber-200',
    text: 'text-amber-700'
  },
  'site-c': {
    bg: 'bg-purple-50/50',
    border: 'border-purple-100 hover:border-purple-200',
    text: 'text-purple-700'
  }
};

const theme = themeColors[siteSlug] || themeColors['matikos'];
---

<section id="services" class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Nos Services & Expertises</h2>
      <p class="mt-4 text-lg text-slate-500">
        Découvrez l'étendue de nos compétences et notre engagement pour des travaux de qualité supérieure, durables et soignés.
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <div class={`hover-lift p-8 rounded-2xl border bg-white shadow-sm transition-all duration-300 ${theme.border}`}>
          <div class={`inline-flex h-12 w-12 items-center justify-center rounded-xl text-2xl mb-6 ${theme.bg}`}>
            {getIcon(service)}
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">{service}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Prestation sur-mesure réalisée dans les règles de l'art par un artisan qualifié avec suivi complet du chantier.
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
