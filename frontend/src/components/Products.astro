---
// Composant Produits — Le Croisetier
// VERSION CARROUSEL INFINI : animation CSS pure, boucle perpétuelle, pause au survol
import { getAssetUrl } from '../lib/directus';

interface Props {
  produits: any[];
  siteSlug?: string;
}

const { produits, siteSlug = 'matikos' } = Astro.props;
const isCroisetier = siteSlug === 'le-croisetier';

// Enrichissement des données de couleur côté serveur
const enriched = produits.map(p => {
  let badgeBg    = 'bg-indigo-50 text-indigo-700 border-indigo-100';
  let badgeLabel = 'Collection';
  if (p.nom.includes('Sauge') || p.nom.toLowerCase().includes('vert')) {
    badgeBg    = 'bg-emerald-50 text-emerald-700 border-emerald-100';
    badgeLabel = 'Vert Sauge';
  } else if (p.nom.includes('Rose')) {
    badgeBg    = 'bg-rose-50 text-rose-700 border-rose-100';
    badgeLabel = 'Rose Poudré';
  } else if (p.nom.includes('Bleu')) {
    badgeBg    = 'bg-sky-50 text-sky-700 border-sky-100';
    badgeLabel = 'Bleu Céleste';
  }
  return { ...p, badgeBg, badgeLabel };
});
---

{produits.length > 0 && (
  isCroisetier ? (
    /* ============================================================
       CARROUSEL INFINI LE CROISETIER
       Principe : on duplique les cartes 4× dans une bande (track)
       animée en boucle CSS. Pause automatique au survol.
       Largeur de carte : 340px, gap : 32px  → 372px par item.
       3 cartes réelles × 372px = 1116px = distance de la boucle.
    ============================================================= */
    <section id="produit" class="py-20 bg-white relative overflow-hidden">

      <!-- En-tête -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12 reveal-on-scroll">
        <h2 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl mb-3 font-inter">
          Nos Croix Collection Pastel
        </h2>
        <p class="text-lg text-slate-500 max-w-xl">
          Trois coloris signature, peints à la main. Glissez pour découvrir — l'animation est infinie.
        </p>
      </div>

      <!-- Masques de fondu gauche/droite -->
      <div class="pointer-events-none absolute left-0 top-0 h-full w-24 bg-gradient-to-r from-white to-transparent z-10"></div>
      <div class="pointer-events-none absolute right-0 top-0 h-full w-24 bg-gradient-to-l from-white to-transparent z-10"></div>

      <!-- Fenêtre du carrousel (overflow:hidden coupe la bande) -->
      <div class="overflow-hidden w-full">
        <!-- Bande animée : les cartes sont répétées 4× pour une boucle sans couture -->
        <div id="infinite-track" class="flex gap-8 w-max">
          {[...enriched, ...enriched, ...enriched, ...enriched].map((produit, idx) => (
            <div class="carousel-card w-[320px] sm:w-[340px] shrink-0 bg-slate-50 rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500 group flex flex-col">
              <!-- Image -->
              <div class="relative overflow-hidden aspect-[3/4] bg-slate-200">
                {produit.image ? (
                  <img
                    src={getAssetUrl(produit.image)}
                    alt={produit.nom}
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
                    loading={idx < 3 ? 'eager' : 'lazy'}
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="text-slate-400 text-sm">Photo bientôt disponible</span>
                  </div>
                )}
                <span class={`absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border shadow-sm ${produit.badgeBg}`}>
                  {produit.badgeLabel}
                </span>
              </div>

              <!-- Infos -->
              <div class="p-6 flex flex-col gap-4 flex-grow justify-between">
                <div>
                  <h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-tight">{produit.nom}</h3>
                  <div class="mt-2 text-slate-500 text-sm line-clamp-2 prose prose-sm" set:html={produit.description} />
                </div>
                <div class="flex items-center justify-between border-t border-slate-100 pt-4">
                  <span class="text-2xl font-extrabold text-slate-900 font-inter">{produit.prix}&thinsp;€</span>
                  <a
                    href={produit.lien_stripe}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-white bg-blue-600 rounded-full hover:bg-blue-700 active:scale-95 transition-all shadow-sm hover:shadow-md"
                    onclick="event.stopPropagation()"
                  >
                    Acheter
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ) : (
    /* ============================================================
       AFFICHAGE GRILLE CLASSIQUE (autres sites)
    ============================================================= */
    <section id="produit" class="py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll">
          <h2 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl mb-6">Le Cadeau Idéal</h2>
          <p class="text-xl text-slate-600">Pour accompagner les grands moments de la vie avec une pièce unique.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-12 items-center">
          {produits.map((produit) => (
            <>
              <div class="relative rounded-3xl overflow-hidden shadow-2xl reveal-on-scroll group">
                {produit.image ? (
                  <img src={getAssetUrl(produit.image)} alt={produit.nom}
                    class="w-full object-cover aspect-[4/5] transform transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[4/5] bg-slate-100 flex items-center justify-center">
                    <span class="text-slate-400">Photo indisponible</span>
                  </div>
                )}
              </div>
              <div class="flex flex-col justify-center space-y-8 reveal-on-scroll" style="transition-delay: 200ms;">
                <div>
                  <h3 class="text-3xl font-bold text-slate-900 mb-4">{produit.nom}</h3>
                  <div class="prose prose-lg text-slate-600 mb-8" set:html={produit.description} />
                  <a href={produit.lien_stripe} target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-emerald-600 rounded-full hover:bg-emerald-700 hover:shadow-lg hover:-translate-y-1 transition-all focus:ring-4 focus:ring-emerald-300">
                    Commander — {produit.prix}&thinsp;€
                  </a>
                </div>
              </div>
            </>
          ))}
        </div>
      </div>
    </section>
  )
)}

<style>
  /* ── Animation infinie de la bande ─────────────────────────────
     Durée ajustée : 3 cartes × 372px = 1116px à parcourir.
     On scroll du 0 jusqu'à -1116px puis on repart de 0.
     La durée détermine la vitesse (20s = confortable).
  ─────────────────────────────────────────────────────────────── */
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-1116px); }  /* (340 + 32) × 3 = 1116 */
  }

  #infinite-track {
    animation: marquee 22s linear infinite;
  }

  /* Pause au survol d'UNE carte */
  #infinite-track:hover {
    animation-play-state: paused;
  }

  /* Empêcher le pointer-events sur les clones de gêner les vrais liens */
  .carousel-card {
    cursor: default;
  }
</style>
