---
// Composant Produits — Le Croisetier
// VERSION CARROUSEL INFINI : animation CSS pure, boucle perpétuelle, pause au survol
import { getAssetUrl } from '../lib/directus';

interface Props {
  produits: any[];
  siteSlug?: string;
}

const { produits, siteSlug = 'matikos' } = Astro.props;
const isCroisetier = siteSlug === 'le-croisetier';

// Enrichissement des données de couleur côté serveur
const enriched = produits.map(p => {
  let badgeBg    = 'bg-indigo-50 text-indigo-700 border-indigo-100';
  let badgeLabel = 'Collection';
  if (p.nom.includes('Sauge') || p.nom.toLowerCase().includes('vert')) {
    badgeBg    = 'bg-emerald-50 text-emerald-700 border-emerald-100';
    badgeLabel = 'Vert Sauge';
  } else if (p.nom.includes('Rose')) {
    badgeBg    = 'bg-rose-50 text-rose-700 border-rose-100';
    badgeLabel = 'Rose Poudré';
  } else if (p.nom.includes('Bleu')) {
    badgeBg    = 'bg-sky-50 text-sky-700 border-sky-100';
    badgeLabel = 'Bleu Céleste';
  }
  return { ...p, badgeBg, badgeLabel };
});
---

{produits.length > 0 && (
  isCroisetier ? (
    /* ============================================================
       CARROUSEL INFINI LE CROISETIER (INTERACTIF & TACTILE)
       Principe : on répète la série 3 fois. Au chargement, on
       se place au milieu. Quand le scroll déborde, on recentre
       immédiatement sans transition, ce qui simule une boucle infinie.
    ============================================================= */
    <section id="produit" class="py-20 bg-white relative overflow-hidden">

      <!-- En-tête simple sans boutons -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12 reveal-on-scroll">
        <h2 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl mb-3 font-inter">
          Nos Croix Collection Pastel
        </h2>
        <p class="text-lg text-slate-500 max-w-xl">
          Trois coloris signature, peints à la main. Glissez pour explorer librement.
        </p>
      </div>

      <!-- Fenêtre du carrousel -->
      <div class="w-full relative overflow-hidden">
        <!-- Masques de fondu gauche/droite confinés au carrousel pour ne pas voiler le titre -->
        <div class="pointer-events-none absolute left-0 top-0 h-full w-12 sm:w-24 bg-gradient-to-r from-white via-white/80 to-transparent z-10"></div>
        <div class="pointer-events-none absolute right-0 top-0 h-full w-12 sm:w-24 bg-gradient-to-l from-white via-white/80 to-transparent z-10"></div>

        <!-- Bande défilante (3 répétitions = 9 cartes pour un scroll manuel libre et léger) -->
        <div id="carousel-track" class="flex gap-8 overflow-x-auto select-none no-scrollbar py-4">
          {[...enriched, ...enriched, ...enriched].map((produit, idx) => (
            <div class="carousel-card w-[290px] sm:w-[340px] shrink-0 bg-slate-50 rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500 group flex flex-col" data-index={idx}>
              <!-- Image -->
              <div class="relative overflow-hidden aspect-[3/4] bg-slate-200">
                {produit.image ? (
                  <img
                    src={getAssetUrl(produit.image)}
                    alt={produit.nom}
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
                    loading={idx >= 3 && idx < 6 ? 'eager' : 'lazy'}
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="text-slate-400 text-sm">Photo bientôt disponible</span>
                  </div>
                )}
                <span class={`absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border shadow-sm ${produit.badgeBg}`}>
                  {produit.badgeLabel}
                </span>
              </div>

              <!-- Infos -->
              <div class="p-6 flex flex-col gap-4 flex-grow justify-between">
                <div>
                  <h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-tight">{produit.nom}</h3>
                  <div class="mt-2 text-slate-500 text-sm line-clamp-2 prose prose-sm" set:html={produit.description} />
                </div>
                <div class="flex items-center justify-between border-t border-slate-100 pt-4">
                  <span class="text-2xl font-extrabold text-slate-900 font-inter">{produit.prix}&thinsp;€</span>
                  <a
                    href={produit.lien_stripe}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-white bg-blue-600 rounded-full hover:bg-blue-700 active:scale-95 transition-all shadow-sm hover:shadow-md"
                    onclick="event.stopPropagation()"
                  >
                    Acheter
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <script>
        const initInfiniteCarousel = () => {
          const track = document.getElementById('carousel-track');
          if (!track) return;

          const cards = Array.from(track.querySelectorAll<HTMLElement>('.carousel-card'));
          if (cards.length < 9) return;

          // Mesure des largeurs pour le calcul du scroll
          const getCardMetrics = () => {
            const cardWidth = cards[0].offsetWidth;
            const gap = cards[1].offsetLeft - (cards[0].offsetLeft + cardWidth);
            const stepWidth = cardWidth + gap;
            const groupWidth = stepWidth * 3;
            return { cardWidth, stepWidth, groupWidth };
          };

          let { stepWidth, groupWidth } = getCardMetrics();

          // Repositionner au centre sur le 2e groupe (index 3)
          const centerScroll = () => {
            track.scrollLeft = groupWidth;
          };

          // Positionnement initial
          centerScroll();

          // Gérer le resize
          window.addEventListener('resize', () => {
            const metrics = getCardMetrics();
            stepWidth = metrics.stepWidth;
            groupWidth = metrics.groupWidth;
            centerScroll();
          });

          // Variables de contrôle de l'autoplay continu
          let animationFrameId: number | undefined;
          let lastTime = 0;
          const speed = 40; // Pixels par seconde (défilement lent et fluide)
          let isInteracting = false;
          let resumeTimeout: number | undefined;
          let scrollTimeout: number | undefined;

          // Boucle d'animation continue (tapis roulant)
          const tick = (timestamp: number) => {
            if (!lastTime) lastTime = timestamp;
            const delta = (timestamp - lastTime) / 1000;
            lastTime = timestamp;

            if (!isInteracting && track) {
              track.scrollLeft += speed * delta;

              // Boucle infinie pendant le défilement automatique
              const currentScroll = track.scrollLeft;
              if (currentScroll >= groupWidth * 2) {
                track.scrollLeft = currentScroll - groupWidth;
              }
            }

            animationFrameId = requestAnimationFrame(tick);
          };

          // Lancer l'animation
          animationFrameId = requestAnimationFrame(tick);

          // Suspendre l'autoplay lors d'une interaction
          const startInteracting = () => {
            isInteracting = true;
            if (resumeTimeout) clearTimeout(resumeTimeout);
          };

          // Reprendre l'autoplay 1s après la fin de l'inactivité
          const stopInteracting = () => {
            if (resumeTimeout) clearTimeout(resumeTimeout);
            resumeTimeout = window.setTimeout(() => {
              isInteracting = false;
              lastTime = 0; // Réinitialiser le timestamp pour éviter les sauts
            }, 1000); // 1 seconde de pause avant reprise
          };

          // Écouteurs pour le survol souris (desktop)
          track.addEventListener('mouseenter', startInteracting);
          track.addEventListener('mouseleave', stopInteracting);

          // Écouteurs pour le tactile (mobile)
          track.addEventListener('touchstart', startInteracting, { passive: true });
          track.addEventListener('touchmove', startInteracting, { passive: true });
          track.addEventListener('touchend', stopInteracting, { passive: true });

          // Recentrage silencieux debouncé (200ms) après le geste manuel
          track.addEventListener('scroll', () => {
            if (!isInteracting) return; // Ne pas interférer avec le défilement automatique

            if (scrollTimeout) clearTimeout(scrollTimeout);
            scrollTimeout = window.setTimeout(() => {
              const currentScroll = track.scrollLeft;

              // Trop à gauche -> recentrage sur le groupe 2
              if (currentScroll < groupWidth - 50) {
                track.scrollLeft = currentScroll + groupWidth;
              }
              // Trop à droite -> recentrage sur le groupe 2
              else if (currentScroll >= groupWidth * 2 - 50) {
                track.scrollLeft = currentScroll - groupWidth;
              }
            }, 200); // 200ms d'inactivité requis après le geste tactile
          });
        };

        // Lancement immédiat et après swaps Astro
        document.addEventListener('DOMContentLoaded', initInfiniteCarousel);
        document.addEventListener('astro:after-swap', initInfiniteCarousel);
        if (document.readyState !== 'loading') initInfiniteCarousel();
      </script>
    </section>
  ) : (
    /* ============================================================
       AFFICHAGE GRILLE CLASSIQUE (autres sites)
    ============================================================= */
    <section id="produit" class="py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll">
          <h2 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl mb-6">Le Cadeau Idéal</h2>
          <p class="text-xl text-slate-600">Pour accompagner les grands moments de la vie avec une pièce unique.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-12 items-center">
          {produits.map((produit) => (
            <>
              <div class="relative rounded-3xl overflow-hidden shadow-2xl reveal-on-scroll group">
                {produit.image ? (
                  <img src={getAssetUrl(produit.image)} alt={produit.nom}
                    class="w-full object-cover aspect-[4/5] transform transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[4/5] bg-slate-100 flex items-center justify-center">
                    <span class="text-slate-400">Photo indisponible</span>
                  </div>
                )}
              </div>
              <div class="flex flex-col justify-center space-y-8 reveal-on-scroll" style="transition-delay: 200ms;">
                <div>
                  <h3 class="text-3xl font-bold text-slate-900 mb-4">{produit.nom}</h3>
                  <div class="prose prose-lg text-slate-600 mb-8" set:html={produit.description} />
                  <a href={produit.lien_stripe} target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-emerald-600 rounded-full hover:bg-emerald-700 hover:shadow-lg hover:-translate-y-1 transition-all focus:ring-4 focus:ring-emerald-300">
                    Commander — {produit.prix}&thinsp;€
                  </a>
                </div>
              </div>
            </>
          ))}
        </div>
      </div>
    </section>
  )
)}

<style>
  /* Masquage de la scrollbar sur le track */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE et Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
