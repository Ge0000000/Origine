---
import type { Createur } from '../lib/types';
import { getAssetUrl } from '../lib/directus';

interface Props {
  createur: Createur;
}

const { createur } = Astro.props;
const logoUrl = getAssetUrl(createur.logo);
---

<div class={`hover-lift relative rounded-3xl border bg-white p-6 shadow-sm transition-all duration-300 ${createur.est_sponsorise ? 'border-amber-400 bg-amber-50/20' : 'border-slate-200/60'}`}>
  
  {createur.est_sponsorise && (
    <span class="absolute top-4 right-4 rounded-full bg-amber-100 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-amber-800">
      ⭐ Sponsorisé
    </span>
  )}

  <div class="flex items-center space-x-4 mb-4">
    <!-- Logo ou Initiales du créateur -->
    <div class="h-16 w-16 shrink-0 overflow-hidden rounded-2xl bg-slate-100 border border-slate-100">
      {logoUrl ? (
        <img src={logoUrl} alt={`Logo de ${createur.nom}`} class="h-full w-full object-cover" />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-amber-100 text-xl font-bold text-amber-800">
          {createur.nom.substring(0, 2).toUpperCase()}
        </div>
      )}
    </div>

    <div>
      <h3 class="text-lg font-bold text-slate-900 leading-snug">{createur.nom}</h3>
      <p class="text-xs font-semibold text-amber-700 tracking-wide uppercase mt-0.5">{createur.specialite}</p>
    </div>
  </div>

  <!-- Description raccourcie -->
  <div class="text-sm text-slate-500 mb-6 leading-relaxed line-clamp-3" set:html={createur.description}></div>

  <!-- Pied de carte : Liens et localisation -->
  <div class="flex items-center justify-between border-t border-slate-100 pt-4 text-xs">
    <span class="text-slate-400 font-medium">📍 {createur.localisation}</span>
    
    <div class="flex items-center space-x-3">
      {createur.instagram_url && (
        <a 
          href={createur.instagram_url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-slate-400 hover:text-slate-600 transition-colors"
          aria-label="Instagram"
        >
          📷
        </a>
      )}
      <a 
        href={`/createurs/${createur.slug}`}
        class="font-bold text-amber-800 hover:text-amber-950 transition-colors hover:underline"
      >
        Voir la fiche →
      </a>
    </div>
  </div>
</div>
