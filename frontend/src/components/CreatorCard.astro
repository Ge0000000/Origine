---
import type { Createur } from '../lib/types';
import { getAssetUrl } from '../lib/directus';

interface Props {
  createur: Createur;
}

const { createur } = Astro.props;
const logoUrl = getAssetUrl(createur.logo);
---

<div class={`group relative overflow-hidden rounded-3xl border bg-white p-6 md:p-8 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl ${createur.est_sponsorise ? 'border-amber-200 bg-gradient-to-b from-amber-50/50 to-white' : 'border-slate-100 hover:border-slate-300'}`}>
  
  {createur.est_sponsorise && (
    <div class="absolute top-0 right-0 overflow-hidden rounded-bl-3xl rounded-tr-3xl">
       <div class="bg-gradient-to-r from-amber-400 to-yellow-500 px-6 py-1.5 text-[10px] font-black uppercase tracking-widest text-white shadow-sm">
         ⭐ Sponsorisé
       </div>
    </div>
  )}

  <div class="flex items-start space-x-5 mb-6 mt-2">
    <!-- Logo ou Initiales du créateur -->
    <div class="relative h-20 w-20 shrink-0 overflow-hidden rounded-2xl bg-slate-50 border border-slate-100 shadow-inner group-hover:scale-105 transition-transform duration-500">
      {logoUrl ? (
        <img src={logoUrl} alt={`Logo de ${createur.nom}`} class="h-full w-full object-cover" />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-amber-100 to-amber-50 text-2xl font-bold text-amber-700">
          {createur.nom.substring(0, 2).toUpperCase()}
        </div>
      )}
    </div>

    <div class="flex-1 pt-1">
      <h3 class="text-xl font-extrabold text-slate-900 leading-snug group-hover:text-amber-800 transition-colors">{createur.nom}</h3>
      <p class="text-xs font-bold text-amber-600 tracking-wider uppercase mt-1 bg-amber-50 inline-block px-2 py-0.5 rounded-md border border-amber-100">{createur.specialite}</p>
    </div>
  </div>

  <!-- Description raccourcie -->
  <div class="text-sm text-slate-600 mb-8 leading-relaxed line-clamp-3 font-medium" set:html={createur.description}></div>

  <!-- Pied de carte : Liens et localisation -->
  <div class="flex items-center justify-between border-t border-slate-100/80 pt-5 mt-auto text-sm">
    <span class="text-slate-500 font-semibold flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-600" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
      </svg>
      {createur.localisation}
    </span>
    
    <div class="flex items-center space-x-4">
      {createur.instagram_url && (
        <a 
          href={createur.instagram_url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-slate-400 hover:text-pink-600 transition-colors hover:scale-110"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      )}
      <a 
        href={`/createurs/${createur.slug}`}
        class="font-extrabold text-amber-700 bg-amber-50 hover:bg-amber-100 px-4 py-2 rounded-xl transition-all hover:shadow-md border border-amber-100"
      >
        Voir la fiche →
      </a>
    </div>
  </div>
</div>
